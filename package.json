{
  "name": "circu-try-3d",
  "version": "1.0.0",
  "description": "3D , Interactive , Electric Circuit Builder that utilizes ohms law and visualises current flow and behavior in a electric circuit down to the atomic level - creating a new way to understand the abstract concepts - Illuminating Electricity",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && tsc -b tsconfig.electron.json && electron .\"",
    "electron:build": "vite build --mode electron && tsc -b tsconfig.electron.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-splash": "node generate-splash-images.js",
    "generate-play-store-icons": "node scripts/generate-play-store-icons.js",
    "generate-feature-graphic": "node scripts/generate-feature-graphic.js",
    "generate-screenshots": "node scripts/generate-screenshots.js",
    "generate-screenshots:local": "node scripts/generate-screenshots.js --local",
    "capture-pr-portrait": "node scripts/capture-pr-portrait.js",
    "capture-pr-portrait:local": "node scripts/capture-pr-portrait.js --base-url http://localhost:4173",
    "circuit-bot": "node scripts/circuit-bot.js",
    "circuit-bot:local": "node scripts/circuit-bot.js --local",
    "circuit-bot:portrait": "node scripts/circuit-bot.js --portrait",
    "circuit-bot:portrait:local": "node scripts/circuit-bot.js --local --portrait",
    "component-showcase": "node scripts/capture-component-showcase.js",
    "component-showcase:local": "node scripts/capture-component-showcase.js --local",
    "content:refresh:local": "npm run generate-screenshots:local && npm run component-showcase:local && npm run circuit-bot:local",
    "smoke:visual": "node scripts/visual-smoke.js --local",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mitchelllorin/CircuiTry3D.git"
  },
  "keywords": [],
  "author": "Mitchell Lorin McKnight",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Mitchelllorin/CircuiTry3D/issues"
  },
  "homepage": "https://github.com/Mitchelllorin/CircuiTry3D#readme",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@fontsource/inter": "^5.2.8",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.0.4",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "playwright": "^1.56.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.4"
  },
  "dependencies": {
    "@capacitor/android": "^7.5.0",
    "@capacitor/app": "^7.1.0",
    "@capacitor/core": "^7.4.4",
    "@capacitor/splash-screen": "^7.0.3",
    "@capacitor/status-bar": "^7.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "express": "^5.2.1",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "node-fetch": "^3.3.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.9.4",
    "three": "^0.181.2"
  }
}
